---
// src/components/CatalogCard.astro
const { title, id, placeholder } = Astro.props;
---

<div class="catalog-group">
    <label for={id}>{title}</label>
    <div class="input-row">
        <input type="number" id={id} placeholder={placeholder} class="catalog-input" data-brand={title}>
        <button type="button" class="download-btn" data-input={id} data-brand={title}>
            Descargar
        </button>
    </div>
</div>

<style>
    .catalog-group {
        margin-bottom: 1.5rem;
    }
    label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 600;
        color: #581c87;
        font-size: 0.95rem;
    }
    .input-row {
        display: flex;
        gap: 10px;
    }
    input {
        flex: 1;
        padding: 0.75rem;
        border: 2px solid #d8b4fe;
        border-radius: 8px;
        font-size: 1rem;
        outline: none;
        transition: border-color 0.3s ease;
    }
    input:focus {
        border-color: #a855f7;
    }
    button {
        background-color: #7e22ce;
        color: white;
        border: none;
        padding: 0 1.2rem;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }
    button:hover {
        background-color: #6b21a8;
    }
    button:disabled {
        background-color: #a5b4fc;
        cursor: not-allowed;
    }
</style>